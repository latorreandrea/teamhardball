# ============================================================
# N.S.O.G. Environment Variables — EXAMPLE FILE
# Copy this file, rename it .env, fill in the values,
# and NEVER commit the real .env to version control.
# In production, set these directly in Cloud Run (see README).
# ============================================================

# Django
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=False
ALLOWED_HOSTS=your-service.run.app,localhost

# PostgreSQL (Cloud SQL or any Postgres)
# Leave empty to use SQLite locally
DATABASE_URL=postgres://user:password@host:5432/dbname

# Gmail SMTP via App Password
# Leave empty to fall back to console backend (dev only)
EMAIL_HOST_USER=nsogcip@gmail.com
EMAIL_HOST_PASSWORD=your-gmail-app-password
DEFAULT_FROM_EMAIL=N.S.O.G. <nsogcip@gmail.com>

# Google Cloud Storage buckets
# Leave empty to serve files locally (dev only)
GS_BUCKET_NAME=nsogcip-static
GS_MEDIA_BUCKET_NAME=nsogcip-media

# Site & integrations
SITE_URL=https://your-service.run.app
DISCORD_LINK=https://discord.gg/nsog-airsoft
